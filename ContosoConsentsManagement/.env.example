# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Full Azure Function URL for uploading email payloads, INCLUDING the function key.
# Example: https://<your-func-app>.azurewebsites.net/api/InsertContent?code=YOUR_FUNCTION_KEY
UPLOAD_ENDPOINT_URL=

# (Optional) Endpoint of the Projects API. Leave empty to use MOCK_PROJECTS in development.
PROJECTS_ENDPOINT_URL=
